#--------------------------------------------------------------------
# Prime Connects — Development Environment
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--- APP ---
app.baseURL = 'http://localhost:8080/'
app.indexPage = ''
app.appTimezone = Asia/Dubai
app.CSPEnabled = false
app.forceGlobalSecureRequests = false
logger.threshold = 4

#--- DATABASE ---
database.default.hostname = 127.0.0.1
database.default.database = primeconnects
database.default.username = root
database.default.password = ''
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci
database.default.DBDebug = true

#--- JWT ---
JWT_SECRET = a3f8b2c1d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2
JWT_TTL = 21600

#--- CORS ---
CORS_ALLOWED_ORIGIN = *

#--- UPLOADS ---
UPLOAD_PUBLIC_DIR = public/uploads

#--- EMAIL (SMTP) ---
email.protocol = smtp
email.SMTPHost = smtp.hostinger.com
email.SMTPUser = noreply@primeconnects.ae
email.SMTPPass = your_smtp_password
email.SMTPPort = 587
email.SMTPCrypto = tls
email.fromEmail = noreply@primeconnects.ae
email.fromName = 'Prime Connects'
email.mailType = html
email.charset = UTF-8
email.wordWrap = true
email.SMTPTimeout = 10

#--- INQUIRY NOTIFICATIONS ---
INQUIRY_NOTIFY_TO = admin@primeconnects.ae
INQUIRY_BCC = ops@primeconnects.ae
INQUIRY_REPLY_TO = support@primeconnects.ae
INQUIRY_SEND_USER_CONFIRMATION = true
